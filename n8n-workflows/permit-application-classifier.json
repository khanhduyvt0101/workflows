      "parameters": {
        "resource": "document",
        "operation": "extract",
        "inputType": "file",
        "binaryPropertyName": "data",
        "prompt": "Extract permit application information: application number, application date, permit type (building/electrical/plumbing/mechanical/demolition/grading/sign/fence/deck/pool/solar/ADU/commercial/new construction/renovation/other), applicant name, applicant address, phone and email, property owner, project street address, city, state, zip, parcel number, zoning district, proposed use, project description, estimated cost, estimated start and end dates, square footage, number of floors, occupancy type, contractor name and license number, list of required documents, and list of any missing or incomplete documents.",
        "schema": "{\"type\": \"object\", \"properties\": {\"applicationNumber\": {\"type\": \"string\"}, \"applicationDate\": {\"type\": \"string\"}, \"permitType\": {\"type\": \"string\"}, \"applicantName\": {\"type\": \"string\"}, \"applicantAddress\": {\"type\": \"string\"}, \"applicantPhone\": {\"type\": \"string\"}, \"applicantEmail\": {\"type\": \"string\"}, \"propertyOwner\": {\"type\": \"string\"}, \"projectStreet\": {\"type\": \"string\"}, \"projectCity\": {\"type\": \"string\"}, \"projectState\": {\"type\": \"string\"}, \"projectZip\": {\"type\": \"string\"}, \"parcelNumber\": {\"type\": \"string\"}, \"zoning\": {\"type\": \"string\"}, \"proposedUse\": {\"type\": \"string\"}, \"projectDescription\": {\"type\": \"string\"}, \"estimatedCost\": {\"type\": \"number\"}, \"estimatedStartDate\": {\"type\": \"string\"}, \"estimatedEndDate\": {\"type\": \"string\"}, \"squareFootage\": {\"type\": \"number\"}, \"floors\": {\"type\": \"number\"}, \"occupancyType\": {\"type\": \"string\"}, \"contractorName\": {\"type\": \"string\"}, \"contractorLicense\": {\"type\": \"string\"}, \"requiredDocuments\": {\"type\": \"string\"}, \"missingDocuments\": {\"type\": \"string\"}}, \"required\": [\"applicationNumber\", \"permitType\", \"applicantName\"], \"additionalProperties\": false}"
      },
