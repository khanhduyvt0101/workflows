    {
      "parameters": {
        "resource": "document",
        "operation": "ask",
        "inputType": "file",
        "binaryPropertyName": "data",
        "prompt": "Classify this permit application:\n\nCOMPLEXITY: Rate as SIMPLE or COMPLEX\n- SIMPLE: Minor repairs, interior non-structural, single-family residential under $50K\n- COMPLEX: Structural changes, new construction, commercial, multi-family, over $50K\n\nCOMPLETENESS: Rate as COMPLETE, NEEDS_INFO, or REJECTED\n- COMPLETE: All required documents present, zoning compliant, no violations\n- NEEDS_INFO: Missing documents, unclear descriptions, or incomplete fields\n- REJECTED: Zoning violation, prohibited use, missing required licenses, or eligibility issues\n\nZONING_CHECK: PASS or FAIL\nENVIRONMENTAL_REVIEW: REQUIRED or NOT_REQUIRED (required if over 1 acre or sensitive area)\n\nMISSING_ITEMS: List each missing item\nREJECTION_REASONS: List each reason if rejected\n\nESTIMATED_REVIEW_DAYS: [number]\n\nFormat your response as:\nCLASSIFICATION: [COMPLETE/NEEDS_INFO/REJECTED]\nCOMPLEXITY: [SIMPLE/COMPLEX]\nZONING_CHECK: [PASS/FAIL]\nENVIRONMENTAL_REVIEW: [REQUIRED/NOT_REQUIRED]\nESTIMATED_REVIEW_DAYS: [number]\nMISSING_ITEMS: [list or None]\nREJECTION_REASONS: [list or None]\nROUTE_TO: [FAST_TRACK/STANDARD_REVIEW/EXPEDITED_HEARING]"
      },
      "id": "pv-classify",
      "name": "Classify Permit",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 1,
      "position": [
        980,
        460
      ],
      "credentials": {
        "pdfVectorApi": {
          "id": "YOUR_PDFVECTOR_CREDENTIAL_ID",
          "name": "PDF Vector"
        }
      }
    },
    {
      "parameters": {
        "mode": "append"
      },
      "id": "merge-results",
      "name": "Merge Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1200,
        360
      ]
    },
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst extractItem = allItems[0]?.json || {};\nconst appData = extractItem.data || extractItem;\nconst classifyItem = allItems[1]?.json || {};\nconst classification = classifyItem.answer || classifyItem.markdown || classifyItem.text || '';\n\nconst triggerData = $('New Application').item.json;\nconst fileName = triggerData.name || 'unknown';\nconst fileId = triggerData.id || '';\n\n// Parse classification response\nconst getField = (text, field) => {\n  const match = text.match(new RegExp(field + '[:\\\\s]+([^\\\\n]+)', 'i'));\n  return match ? match[1].trim() : 'N/A';\n};\n\nconst status = getField(classification, 'CLASSIFICATION');\nconst complexity = getField(classification, 'COMPLEXITY');\nconst zoningCheck = getField(classification, 'ZONING_CHECK');\nconst envReview = getField(classification, 'ENVIRONMENTAL_REVIEW');\nconst estDays = getField(classification, 'ESTIMATED_REVIEW_DAYS');\nconst routeTo = getField(classification, 'ROUTE_TO');\nconst missingItems = getField(classification, 'MISSING_ITEMS');\nconst rejectionReasons = getField(classification, 'REJECTION_REASONS');\n\n// Normalize status\nlet routingStatus = 'NEEDS_INFO';\nif (status.toUpperCase().includes('COMPLETE')) routingStatus = 'COMPLETE';\nelse if (status.toUpperCase().includes('REJECT')) routingStatus = 'REJECTED';\n\nreturn [{ json: {\n  applicationNumber: appData.applicationNumber || 'N/A',\n  applicationDate: appData.applicationDate || 'N/A',\n  applicantName: appData.applicantName || 'N/A',\n  applicantEmail: appData.applicantEmail || 'N/A',\n  permitType: appData.permitType || 'N/A',\n  projectAddress: `${appData.projectStreet || ''} ${appData.projectCity || ''}`.trim() || 'N/A',\n  estimatedCost: appData.estimatedCost || 0,\n  complexity, zoningCheck, envReview,\n  routeTo, estDays, missingItems, rejectionReasons,\n  routingStatus,\n  classification,\n  fileName, fileId,\n  processedAt: new Date().toISOString()\n}}];"
      },
