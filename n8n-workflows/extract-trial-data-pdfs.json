    {
      "parameters": {
        "resource": "document",
        "operation": "extract",
        "inputType": "file",
        "binaryPropertyName": "data",
        "prompt": "Extract clinical trial document information including: study identifier, protocol number, phase (I/II/III/IV), sponsor name, indication/disease area, study design (randomized/blinded/controlled), primary endpoint with definition, secondary endpoints, sample size (target enrollment), study duration, inclusion criteria, exclusion criteria, dosing schedule, adverse events summary, serious adverse events count, efficacy results if available, statistical methods, regulatory status, and any key findings or conclusions.",
        "schema": "{\"type\":\"object\",\"properties\":{\"studyId\":{\"type\":\"string\"},\"protocolNumber\":{\"type\":\"string\"},\"phase\":{\"type\":\"string\"},\"sponsor\":{\"type\":\"string\"},\"indication\":{\"type\":\"string\"},\"studyDesign\":{\"type\":\"string\"},\"primaryEndpoint\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"definition\":{\"type\":\"string\"},\"measurementMethod\":{\"type\":\"string\"}}},\"secondaryEndpoints\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"definition\":{\"type\":\"string\"}}}},\"sampleSize\":{\"type\":\"object\",\"properties\":{\"target\":{\"type\":\"number\"},\"enrolled\":{\"type\":\"number\"},\"completed\":{\"type\":\"number\"}}},\"studyDuration\":{\"type\":\"string\"},\"inclusionCriteria\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"exclusionCriteria\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"dosingSchedule\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"arm\":{\"type\":\"string\"},\"dose\":{\"type\":\"string\"},\"frequency\":{\"type\":\"string\"},\"route\":{\"type\":\"string\"}}}},\"adverseEvents\":{\"type\":\"object\",\"properties\":{\"total\":{\"type\":\"number\"},\"serious\":{\"type\":\"number\"},\"commonEvents\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}}},\"efficacyResults\":{\"type\":\"string\"},\"statisticalMethods\":{\"type\":\"string\"},\"regulatoryStatus\":{\"type\":\"string\"},\"keyFindings\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}},\"required\":[\"studyId\",\"phase\"],\"additionalProperties\":false}"
      },
      "id": "pdfvector-extract",
      "name": "Extract Trial Data",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 1,
      "position": [
        880,
        280
      ],
      "credentials": {
        "pdfVectorApi": {
          "id": "YOUR_PDFVECTOR_CREDENTIAL_ID",
          "name": "PDF Vector"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const extractData = $input.first().json.data || $input.first().json;\nconst triggerData = $('New Trial Document').item.json;\n\nconst trial = extractData;\nconst fileName = triggerData.name || 'unknown';\nconst fileId = triggerData.id || '';\n\n// Format secondary endpoints\nconst secondaryEndpoints = trial.secondaryEndpoints || [];\nconst secondaryList = secondaryEndpoints.map(e => e.name).join(', ') || 'None listed';\n\n// Format adverse events\nconst ae = trial.adverseEvents || {};\nconst aeTotal = ae.total || 0;\nconst aeSAE = ae.serious || 0;\nconst aeCommon = (ae.commonEvents || []).join(', ') || 'Not reported';\n\n// Format key findings\nconst findings = trial.keyFindings || [];\nconst findingsList = findings.map((f, i) => `${i + 1}. ${f}`).join('\\n') || 'None extracted';\n\n// Sample size info\nconst sampleSize = trial.sampleSize || {};\nconst sampleTarget = sampleSize.target || 'N/A';\nconst sampleEnrolled = sampleSize.enrolled || 'N/A';\nconst sampleCompleted = sampleSize.completed || 'N/A';\n\n// Primary endpoint info\nconst primaryEP = trial.primaryEndpoint || {};\nconst primaryName = primaryEP.name || 'Not specified';\nconst primaryDef = primaryEP.definition || '';\n\nreturn [{\n  json: {\n    studyId: trial.studyId || 'Unknown',\n    protocolNumber: trial.protocolNumber || 'N/A',\n    phase: trial.phase || 'Unknown',\n    sponsor: trial.sponsor || 'Unknown',\n    indication: trial.indication || 'Not specified',\n    studyDesign: trial.studyDesign || 'Not specified',\n    primaryEndpoint: primaryName,\n    primaryEndpointDefinition: primaryDef,\n    secondaryEndpoints: secondaryList,\n    secondaryCount: secondaryEndpoints.length,\n    sampleTarget: sampleTarget,\n    sampleEnrolled: sampleEnrolled,\n    sampleCompleted: sampleCompleted,\n    studyDuration: trial.studyDuration || 'N/A',\n    aeTotal: aeTotal,\n    aeSAE: aeSAE,\n    aeCommon: aeCommon,\n    regulatoryStatus: trial.regulatoryStatus || 'Unknown',\n    keyFindings: findingsList,\n    findingsCount: findings.length,\n    fileName: fileName,\n    fileId: fileId,\n    processedAt: new Date().toISOString()\n  }\n}];"
      },
      "id": "format-data",
      "name": "Format Trial Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
        280
      ]
    },
