    {
      "parameters": {
        "operation": "ask",
        "inputType": "file",
        "question": "Based on this document, provide: 1) A 3-4 sentence executive summary, 2) The single most important takeaway for business leaders, 3) Three actionable next steps based on the findings, and 4) Who should read this document and why."
      },
      "id": "pdfvector-summary",
      "name": "PDF Vector - Generate Summary",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 2,
      "position": [
        976,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const doc = $('PDF Vector - Extract Info').item.json.data || $('PDF Vector - Extract Info').item.json;\nconst summary = $input.first().json.answer || $input.first().json.markdown || '';\nconst fileName = $('Google Drive Trigger').item.json.name;\nconst fileId   = $('Google Drive Trigger').item.json.id;\n\nconst stats    = (doc.keyStatisticsList   || '').split(';').filter(Boolean);\nconst findings = (doc.mainFindingsList    || '').split(';').filter(Boolean);\nconst recs     = (doc.recommendationsList || '').split(';').filter(Boolean);\n\nconst statsList    = stats.map(s => `📊 ${s.trim()}`).join('\\n')           || 'None extracted';\nconst findingsList = findings.map((f,i) => `${i+1}. ${f.trim()}`).join('\\n') || 'None listed';\nconst recsList     = recs.map(r => `✓ ${r.trim()}`).join('\\n')             || 'None provided';\n\nreturn [{ json: {\n  title:           doc.title           || 'Unknown',\n  author:          doc.author          || 'N/A',\n  organization:    doc.organization    || 'N/A',\n  documentType:    doc.documentType    || 'Other',\n  industry:        doc.industry        || 'N/A',\n  publicationDate: doc.publicationDate || 'N/A',\n  pageCount:       doc.pageCount       || 'N/A',\n  keywordsList:    doc.keywordsList    || 'None',\n  executiveSummary: summary,\n  statsList,    statsCount:    stats.length,\n  findingsList, findingsCount: findings.length,\n  recsList,     recsCount:     recs.length,\n  fileName, fileId,\n  processedAt: new Date().toISOString()\n}}];"
      },
      "id": "compile-summary",
      "name": "Compile Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1184,
