    {
      "parameters": {
        "operation": "extract",
        "inputType": "file",
        "prompt": "Extract whitepaper or report data as flat fields. title, author, organization, publicationDate, documentType (one of: Whitepaper, Research Report, Industry Report, Case Study, Technical Document, Annual Report, Market Analysis, Other), pageCount (number), industry, mainThesis, methodology, keyStatisticsList (semicolon-separated key stats as single string), mainFindingsList (semicolon-separated main findings), conclusionsList (semicolon-separated conclusions), recommendationsList (semicolon-separated recommendations), dataSourcesList (semicolon-separated data sources cited), keywordsList (comma-separated keywords).",
        "schema": "{\"type\": \"object\", \"properties\": {\"title\": {\"type\": \"string\"}, \"author\": {\"type\": \"string\"}, \"organization\": {\"type\": \"string\"}, \"publicationDate\": {\"type\": \"string\"}, \"documentType\": {\"type\": \"string\"}, \"pageCount\": {\"type\": \"number\"}, \"industry\": {\"type\": \"string\"}, \"mainThesis\": {\"type\": \"string\"}, \"methodology\": {\"type\": \"string\"}, \"keyStatisticsList\": {\"type\": \"string\"}, \"mainFindingsList\": {\"type\": \"string\"}, \"conclusionsList\": {\"type\": \"string\"}, \"recommendationsList\": {\"type\": \"string\"}, \"dataSourcesList\": {\"type\": \"string\"}, \"keywordsList\": {\"type\": \"string\"}}, \"additionalProperties\": false}"
      },
      "id": "pdfvector-extract",
      "name": "PDF Vector - Extract Info",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 2,
      "position": [
        576,
        48
      ]
    },
    {
      "parameters": {
