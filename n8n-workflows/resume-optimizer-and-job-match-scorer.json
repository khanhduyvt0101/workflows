            "Test Result": "={{ $json.testResult }}",
            "Deficiency Type": "={{ $json.deficiencyType }}",
            "Remediation Required": "={{ $json.remediationRequired }}",
            "Remediation Plan": "={{ $json.remediationPlan }}",
            "Due Date": "={{ $json.remediationDueDate }}",
            "Assessment": "={{ $json.evidenceAssessment }}",
            "File Name": "={{ $json.fileName }}",
            "Processed Date": "={{ $json.processedAt }}"
          },
          "matchingColumns": [],
