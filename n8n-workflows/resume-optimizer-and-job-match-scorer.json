          "value": "={{ $json.id }}",
          "mode": "id"
        },
        "options": {}
      },
      "id": "1f2260c0-7a26-464a-9d1f-7fc1ac8e2a22",
      "name": "Download Evidence",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        1280,
        420
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "YOUR_GOOGLE_DRIVE_CREDENTIAL_ID",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "operation": "extract",
        "inputType": "file",
        "prompt": "Extract SOX control evidence details from this document. Focus on control ID, control name, owner, process area, test result, exceptions, remediation status, testing date, and auditor comments. Return only fields supported by the document.",
        "schema": "{\"type\":\"object\",\"properties\":{\"controlId\":{\"type\":\"string\"},\"controlName\":{\"type\":\"string\"},\"controlOwner\":{\"type\":\"string\"},\"controlType\":{\"type\":\"string\"},\"processArea\":{\"type\":\"string\"},\"evidencePeriod\":{\"type\":\"string\"},\"testingDate\":{\"type\":\"string\"},\"testerName\":{\"type\":\"string\"},\"sampleSize\":{\"type\":\"number\"},\"exceptionCount\":{\"type\":\"number\"},\"testResult\":{\"type\":\"string\"},\"deficiencyType\":{\"type\":\"string\"},\"remediationRequired\":{\"type\":\"boolean\"},\"remediationPlan\":{\"type\":\"string\"},\"remediationDueDate\":{\"type\":\"string\"},\"auditorComments\":{\"type\":\"string\"}},\"required\":[\"controlId\",\"controlName\",\"testResult\"],\"additionalProperties\":false}"
      },
      "id": "97c2f2e2-f0de-4a54-9300-213a55f44e7b",
      "name": "Extract Control Evidence",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 2,
      "position": [
        1500,
        320
      ],
      "credentials": {
        "pdfVectorApi": {
          "id": "YOUR_PDFVECTOR_CREDENTIAL_ID",
          "name": "PDF Vector account"
        }
      }
    },
    {
      "parameters": {
        "operation": "ask",
        "inputType": "file",
        "question": "You are an internal controls auditor. Review this SOX evidence document and answer in this exact format:\n\nEVIDENCE_STATUS: [SUFFICIENT / PARTIAL / INSUFFICIENT]\nCONTROL_SUPPORT: [brief explanation]\nMISSING_ITEMS: [required evidence or context that is missing]\nRISK_LEVEL: [LOW / MEDIUM / HIGH]\nREMEDIATION_NOTE: [recommended next step if evidence is incomplete]\n\nDo not invent evidence. If the document does not support a claim, say so."
      },
      "id": "9f7a2acf-f520-48be-9c91-3f722e303872",
      "name": "Assess Evidence Sufficiency",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 2,
      "position": [
        1500,
        520
      ],
      "credentials": {
        "pdfVectorApi": {
          "id": "YOUR_PDFVECTOR_CREDENTIAL_ID",
          "name": "PDF Vector account"
        }
      }
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineByPosition",
        "options": {}
      },
      "id": "d7cfd91b-53e1-456b-b555-6e0fa505f6bb",
      "name": "Merge Evidence Review",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1720,
        420
      ]
    },
    {
      "parameters": {
        "jsCode": "const allInputs = $input.all();\nconst extracted = (allInputs[0]?.json?.data || allInputs[0]?.json) || {};\nconst assessment = allInputs[1]?.json?.answer || allInputs[1]?.json?.markdown || '';\nconst fileName = $('New Evidence Document').item.json.name;\nconst fileId = $('New Evidence Document').item.json.id;\n\nconst remediationRequired = extracted.remediationRequired === true || /EVIDENCE_STATUS:\\s*(PARTIAL|INSUFFICIENT)/i.test(assessment) || /RISK_LEVEL:\\s*(MEDIUM|HIGH)/i.test(assessment);\n\nreturn [{\n  json: {\n    controlId: extracted.controlId || 'N/A',\n    controlName: extracted.controlName || 'N/A',\n    controlOwner: extracted.controlOwner || 'N/A',\n    controlType: extracted.controlType || 'N/A',\n    processArea: extracted.processArea || 'N/A',\n    evidencePeriod: extracted.evidencePeriod || 'N/A',\n    testingDate: extracted.testingDate || 'N/A',\n    testerName: extracted.testerName || 'N/A',\n    sampleSize: Number(extracted.sampleSize || 0),\n    exceptionCount: Number(extracted.exceptionCount || 0),\n    testResult: extracted.testResult || 'N/A',\n    deficiencyType: extracted.deficiencyType || 'none',\n    remediationRequired,\n    remediationPlan: extracted.remediationPlan || 'Review evidence sufficiency assessment',\n    remediationDueDate: extracted.remediationDueDate || 'N/A',\n    auditorComments: extracted.auditorComments || 'None',\n    evidenceAssessment: assessment,\n    fileName,\n    fileId,\n    processedAt: new Date().toISOString()\n  }\n}];"
      },
      "id": "5a152e7b-9f21-49a1-a60e-a15b8bff2476",
      "name": "Format Evidence Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1940,
        420
      ]
    },
