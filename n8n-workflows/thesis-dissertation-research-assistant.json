      "id": "drive-download",
      "name": "Download Document",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        480,
        200
      ]
    },
    {
      "parameters": {
        "operation": "extract",
        "inputType": "file",
        "prompt": "Extract thesis or research document content as flat fields. documentTitle, chapterTitle, authorName, institution, year, thesisStatement (main argument or claim), methodology, theoreticalFramework, keyConceptsList (comma-separated key concepts), mainFindingsList (semicolon-separated main findings), researchQuestionsList (semicolon-separated research questions), keywordsList (comma-separated keywords for academic search), citationCount (number), pageCount (number), fieldOfStudy.",
        "schema": "{\"type\": \"object\", \"properties\": {\"documentTitle\": {\"type\": \"string\"}, \"chapterTitle\": {\"type\": \"string\"}, \"authorName\": {\"type\": \"string\"}, \"institution\": {\"type\": \"string\"}, \"year\": {\"type\": \"string\"}, \"thesisStatement\": {\"type\": \"string\"}, \"methodology\": {\"type\": \"string\"}, \"theoreticalFramework\": {\"type\": \"string\"}, \"keyConceptsList\": {\"type\": \"string\"}, \"mainFindingsList\": {\"type\": \"string\"}, \"researchQuestionsList\": {\"type\": \"string\"}, \"keywordsList\": {\"type\": \"string\"}, \"citationCount\": {\"type\": \"number\"}, \"pageCount\": {\"type\": \"number\"}, \"fieldOfStudy\": {\"type\": \"string\"}}, \"additionalProperties\": false}"
      },
      "id": "pdfvector-extract",
      "name": "PDF Vector - Extract Content",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 2,
      "position": [
        680,
        200
      ]
    },
    {
      "parameters": {
        "operation": "search",
        "query": "={{ $json.data?.keywordsList ? $json.data.keywordsList.split(',').slice(0,4).join(' ') : $json.data?.documentTitle || '' }}",
        "providers": [
          "semantic-scholar",
          "pubmed",
          "arxiv"
        ],
        "limit": 15,
        "additionalFields": {},
        "resource": "academic"
      },
      "id": "pdfvector-search",
      "name": "PDF Vector - Find Related Papers",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 2,
      "position": [
        880,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = ($('PDF Vector - Extract Content').item.json?.data || $('PDF Vector - Extract Content').item.json) || {};\nconst papers = $input.first().json.results || [];\nconst fileName = $('Google Drive Trigger').item.json.name;\nconst fileId   = $('Google Drive Trigger').item.json.id;\n\nconst topPapers = papers.slice(0, 5);\nconst relatedPapersList = topPapers.map((p,i) =>\n  `${i+1}. ${p.title || 'Untitled'} (${p.year || 'N/A'}) — ${p.citationCount || 0} citations`\n).join('\\n') || 'None found';\n\nconst searchTerms = (data.keywordsList || data.documentTitle || '').split(',').slice(0,4).join(', ');\n\nreturn [{ json: {\n  title:            data.documentTitle      || 'Unknown',\n  documentTitle:    data.documentTitle      || 'Unknown',\n  chapterTitle:     data.chapterTitle       || 'N/A',\n  thesisStatement:  data.thesisStatement    || 'N/A',\n  methodology:      data.methodology        || 'N/A',\n  theoreticalFramework: data.theoreticalFramework || 'N/A',\n  keyConcepts:      data.keyConceptsList    || 'N/A',\n  keyConceptsList:  data.keyConceptsList    || 'N/A',\n  mainFindingsList: data.mainFindingsList   || 'N/A',\n  researchQuestions: data.researchQuestionsList || 'N/A',\n  researchQuestionsList: data.researchQuestionsList || 'N/A',\n  keywordsList:     data.keywordsList       || 'N/A',\n  searchTerms,\n  papersFound:      papers.length,\n  paperCount:       papers.length,\n  relatedPapersList,\n  readingList:      relatedPapersList,\n  fileName, fileId,\n  processedAt: new Date().toISOString()\n}}];"
      },
      "id": "compile-research",
      "name": "Compile Research",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1080,
