    {
      "parameters": {
        "resource": "document",
        "operation": "extract",
        "inputType": "file",
        "prompt": "Extract medical bill or Explanation of Benefits (EOB) data as flat fields. patientName, patientDOB, patientId, providerName, providerNpi, billDate (YYYY-MM-DD), serviceDate (YYYY-MM-DD), totalCharged (number), insurancePaid (number), adjustments (number), patientOwed (number), deductible (number), copay (number), procedureCodes (comma-separated CPT codes), diagnosisCodes (comma-separated ICD codes), lineItemsSummary (plain text of all charges), duplicateChargesFound (true/false), unbundlingDetected (true/false), upcoding (true/false), billingErrorCount (number), errorDescription (comma-separated description of errors found).",
        "schema": "{\"type\": \"object\", \"properties\": {\"patientName\": {\"type\": \"string\"}, \"patientDOB\": {\"type\": \"string\"}, \"patientId\": {\"type\": \"string\"}, \"providerName\": {\"type\": \"string\"}, \"providerNpi\": {\"type\": \"string\"}, \"billDate\": {\"type\": \"string\"}, \"serviceDate\": {\"type\": \"string\"}, \"totalCharged\": {\"type\": \"number\"}, \"insurancePaid\": {\"type\": \"number\"}, \"adjustments\": {\"type\": \"number\"}, \"patientOwed\": {\"type\": \"number\"}, \"deductible\": {\"type\": \"number\"}, \"copay\": {\"type\": \"number\"}, \"procedureCodes\": {\"type\": \"string\"}, \"diagnosisCodes\": {\"type\": \"string\"}, \"lineItemsSummary\": {\"type\": \"string\"}, \"duplicateChargesFound\": {\"type\": \"boolean\"}, \"unbundlingDetected\": {\"type\": \"boolean\"}, \"upcoding\": {\"type\": \"boolean\"}, \"billingErrorCount\": {\"type\": \"number\"}, \"errorDescription\": {\"type\": \"string\"}}, \"additionalProperties\": false}"
      },
      "id": "1c2e7f71-52c6-4f12-8443-34e94c1886b9",
      "name": "Extract Charges",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 1,
      "position": [
        2976,
        176
      ]
    },
    {
      "parameters": {
        "resource": "document",
        "operation": "ask",
        "inputType": "file",
        "prompt": "Review this medical bill for billing errors. Check for: 1) Duplicate charges (same procedure billed twice), 2) Unbundling (charging separately for procedures that should be bundled), 3) Upcoding (billing for more expensive service than provided), 4) Services not rendered, 5) Incorrect patient information. Return: errorCount (number), estimatedDisputeAmount (dollar amount), disputeRecommendation (dispute/review/ok), specificErrors (list each error clearly), recommendedAction (what patient should do next)."
      },
      "id": "2c4ce079-32f6-4c33-98e3-dbd1571aa9b2",
      "name": "Analyze Errors",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 1,
      "position": [
        2976,
        352
      ]
    },
    {
      "parameters": {},
      "id": "7f3985af-95a5-4a25-a2bd-ba26b595f846",
      "name": "Merge Analysis",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2.1,
      "position": [
        3184,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst allItems = $input.all();\nconst bill = (allItems[0]?.json?.data || allItems[0]?.json) || {};\nconst analysis = allItems[1]?.json || {};\nconst aiText = analysis.answer || analysis.markdown || analysis.text || '';\n\nconst triggerData = $('New Medical Bill').item.json;\nconst fileId = triggerData.id || '';\nconst fileName = triggerData.name || 'unknown';\n\nconst totalCharged = parseFloat(bill.totalCharged) || 0;\nconst insurancePaid = parseFloat(bill.insurancePaid) || 0;\nconst patientOwed = parseFloat(bill.patientOwed) || 0;\nconst billingErrors = parseInt(bill.billingErrorCount) || 0;\n\n// Extract dispute amount from AI\nlet disputeAmount = 0;\nconst dispMatch = aiText.match(/dispute(?:d)? amount[:\\s]*\\$?([\\d,]+(?:\\.\\d+)?)/i) ||\n                  aiText.match(/\\$([\\d,]+(?:\\.\\d+)?)\\s*(?:in dispute|disputeable|overcharged)/i);\nif (dispMatch) disputeAmount = parseFloat(dispMatch[1].replace(/,/g,''));\n\nconst hasErrors = billingErrors > 0 || bill.duplicateChargesFound || bill.unbundlingDetected;\nconst status = hasErrors ? 'PENDING_REVIEW' : 'CLEAN';\n\nreturn [{ json: {\n  fileId, fileName,\n  patientName: bill.patientName || 'Unknown',\n  providerName: bill.providerName || 'Unknown',\n  billDate: bill.billDate || 'N/A',\n  serviceDate: bill.serviceDate || 'N/A',\n  totalCharged,\n  insurancePaid,\n  patientOwed,\n  billingErrors,\n  duplicateCharges: bill.duplicateChargesFound ? 'Yes' : 'No',\n  unbundling: bill.unbundlingDetected ? 'Yes' : 'No',\n  errorDescription: bill.errorDescription || 'None found',\n  disputeAmount,\n  aiAnalysis: aiText.slice(0, 400),\n  status,\n  processedAt: new Date().toISOString()\n}}];"
      },
