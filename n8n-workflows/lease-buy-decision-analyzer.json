    {
      "parameters": {
        "jsCode": "\nconst allItems = $input.all();\nconst a = (allItems[0]?.json?.data || allItems[0]?.json) || {};\nconst b = (allItems[1]?.json?.data || allItems[1]?.json) || {};\n\nconst triggerData = $('New Agreement').item.json;\nconst fileId = triggerData.id || '';\n\nfunction fiveYearCost(doc) {\n  const monthly = parseFloat(doc.monthlyPayment) || 0;\n  const down    = parseFloat(doc.downPayment)    || 0;\n  const maint   = parseFloat(doc.maintenanceCost)|| 0;\n  const ins     = parseFloat(doc.insuranceCost)  || 0;\n  const taxes   = parseFloat(doc.taxesFees)      || 0;\n  const residual= parseFloat(doc.residualValue)  || 0;\n  const endVal  = parseFloat(doc.endOfTermValue) || 0;\n  // 5-year = 60 months payments + down + 5yr maintenance + insurance + taxes - residual value retained\n  return (monthly * 60) + down + (maint * 5) + (ins * 5) + taxes - endVal;\n}\n\nconst costA = fiveYearCost(a);\nconst costB = fiveYearCost(b);\nconst diff  = Math.abs(costA - costB);\nconst winner = costA < costB ? (a.agreementLabel || 'Doc A') : (b.agreementLabel || 'Doc B');\nconst savings = diff.toFixed(2);\n\nreturn [{ json: {\n  fileId,\n  labelA: a.agreementLabel || a.documentType || 'Document A',\n  labelB: b.agreementLabel || b.documentType || 'Document B',\n  assetName: a.assetName || b.assetName || 'Asset',\n  typeA: a.documentType || 'N/A',\n  typeB: b.documentType || 'N/A',\n  monthlyA: parseFloat(a.monthlyPayment) || 0,\n  monthlyB: parseFloat(b.monthlyPayment) || 0,\n  fiveYearCostA: costA.toFixed(2),\n  fiveYearCostB: costB.toFixed(2),\n  costDifference: diff.toFixed(2),\n  recommendation: winner,\n  savings,\n  keyTermsA: a.keyTerms || 'N/A',\n  keyTermsB: b.keyTerms || 'N/A',\n  hiddenCostsA: a.hiddenCosts || 'None noted',\n  hiddenCostsB: b.hiddenCosts || 'None noted',\n  processedAt: new Date().toISOString()\n}}];"
      },
