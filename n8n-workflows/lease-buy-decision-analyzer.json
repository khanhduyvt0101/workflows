        "prompt": "Extract financial agreement data as flat fields. documentType (lease/purchase/loan/other), agreementLabel (short label like 'Lease Option A'), assetName (what is being leased or purchased), monthlyPayment (number), termMonths (number), totalPayments (monthlyPayment * termMonths), downPayment (number), purchasePrice (number), interestRate (number as percent), residualValue (end-of-term residual or buyout, number), maintenanceCost (estimated annual maintenance, number), insuranceCost (annual, number), taxesFees (total taxes and fees, number), endOfTermValue (asset value at end of term, number), keyTerms (3-5 key terms summary), hiddenCosts (any hidden or extra costs mentioned).",
        "schema": "{\"type\": \"object\", \"properties\": {\"documentType\": {\"type\": \"string\"}, \"agreementLabel\": {\"type\": \"string\"}, \"assetName\": {\"type\": \"string\"}, \"monthlyPayment\": {\"type\": \"number\"}, \"termMonths\": {\"type\": \"number\"}, \"totalPayments\": {\"type\": \"number\"}, \"downPayment\": {\"type\": \"number\"}, \"purchasePrice\": {\"type\": \"number\"}, \"interestRate\": {\"type\": \"number\"}, \"residualValue\": {\"type\": \"number\"}, \"maintenanceCost\": {\"type\": \"number\"}, \"insuranceCost\": {\"type\": \"number\"}, \"taxesFees\": {\"type\": \"number\"}, \"endOfTermValue\": {\"type\": \"number\"}, \"keyTerms\": {\"type\": \"string\"}, \"hiddenCosts\": {\"type\": \"string\"}}, \"additionalProperties\": false}"
