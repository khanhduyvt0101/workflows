      "parameters": {
        "operation": "extract",
        "inputType": "file",
        "prompt": "Extract competitor intelligence as flat fields. competitorName, documentType, reportPeriod, revenue (number), revenueGrowth, grossMargin, netIncome, newProductsList (semicolon-separated new products/features announced), partnershipsList (semicolon-separated new partnerships), acquisitionsList (semicolon-separated acquisitions), marketExpansionList (semicolon-separated new markets entered), technologyInvestments (semicolon-separated tech investments), threatsList (semicolon-separated threats to our business), opportunitiesList (semicolon-separated opportunities we can exploit), keyQuotesList (semicolon-separated notable executive quotes), headcountChange, strategicPriority1, strategicPriority2, strategicPriority3.",
        "schema": "{\"type\": \"object\", \"properties\": {\"competitorName\": {\"type\": \"string\"}, \"documentType\": {\"type\": \"string\"}, \"reportPeriod\": {\"type\": \"string\"}, \"revenue\": {\"type\": \"number\"}, \"revenueGrowth\": {\"type\": \"string\"}, \"grossMargin\": {\"type\": \"string\"}, \"netIncome\": {\"type\": \"number\"}, \"newProductsList\": {\"type\": \"string\"}, \"partnershipsList\": {\"type\": \"string\"}, \"acquisitionsList\": {\"type\": \"string\"}, \"marketExpansionList\": {\"type\": \"string\"}, \"technologyInvestments\": {\"type\": \"string\"}, \"threatsList\": {\"type\": \"string\"}, \"opportunitiesList\": {\"type\": \"string\"}, \"keyQuotesList\": {\"type\": \"string\"}, \"headcountChange\": {\"type\": \"string\"}, \"strategicPriority1\": {\"type\": \"string\"}, \"strategicPriority2\": {\"type\": \"string\"}, \"strategicPriority3\": {\"type\": \"string\"}}, \"additionalProperties\": false}"
      },
      "id": "c5b05f18-dbba-4aaa-adb5-4ac4d1510545",
