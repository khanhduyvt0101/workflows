    {
      "parameters": {
        "operation": "ask",
        "inputType": "file",
        "question": "Based on this document, provide: 1) A 2-3 sentence executive summary of the competitor's current position, 2) The top 3 strategic moves we should watch, 3) How this might impact our business, and 4) Recommended actions for our team."
      },
      "id": "2dfde235-53e9-40ca-96cc-abffdf995ba2",
      "name": "PDF Vector - Strategic Insights",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 2,
      "position": [
        976,
        272
      ],
      "credentials": {
        "pdfVectorApi": {
          "id": "YOUR_PDFVECTOR_CREDENTIAL_ID",
          "name": "PDF Vector account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const intel = $('PDF Vector - Extract Intel').item.json.data || $('PDF Vector - Extract Intel').item.json;\nconst insights = $input.first().json.answer || $input.first().json.markdown || '';\nconst fileName = $('Google Drive Trigger').item.json.name;\nconst fileId   = $('Google Drive Trigger').item.json.id;\n\n// Count threats and opportunities\nconst threats      = (intel.threatsList      || '').split(';').filter(t => t.trim()).length;\nconst opportunities= (intel.opportunitiesList|| '').split(';').filter(o => o.trim()).length;\n\n// Build initiatives list\nconst initiatives = [intel.strategicPriority1, intel.strategicPriority2, intel.strategicPriority3]\n  .filter(Boolean).map((p,i) => `${i+1}. ${p}`).join('\\n') || 'N/A';\n\n// Financial summary\nconst financialSummary = intel.revenue\n  ? `Revenue: $${intel.revenue.toLocaleString()} | Growth: ${intel.revenueGrowth || 'N/A'} | Margin: ${intel.grossMargin || 'N/A'}`\n  : `Growth: ${intel.revenueGrowth || 'N/A'} | Margin: ${intel.grossMargin || 'N/A'}`;\n\nreturn [{ json: {\n  companyName:       intel.competitorName       || 'Unknown',\n  documentType:      intel.documentType         || 'N/A',\n  reportPeriod:      intel.reportPeriod         || 'N/A',\n  financialSummary,\n  newProducts:       intel.newProductsList      || 'None',\n  partnershipsList:  intel.partnershipsList     || 'None',\n  acquisitionsList:  intel.acquisitionsList     || 'None',\n  initiativesList:   initiatives,\n  threatsList:       intel.threatsList          || 'None',\n  opportunitiesList: intel.opportunitiesList    || 'None',\n  threatCount:       threats,\n  opportunityCount:  opportunities,\n  strategicInsights: insights,\n  fileName, fileId,\n  processedAt: new Date().toISOString()\n}}];"
      },
