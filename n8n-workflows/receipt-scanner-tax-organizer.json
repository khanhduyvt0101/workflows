      ]
    },
    {
      "parameters": {
        "content": "### 3. Log & route\nSaves to database, routes deductibles separately",
        "height": 80,
        "width": 380
      },
      "id": "082dfc6d-6fbf-4ad7-82c6-14fe79612619",
      "name": "Sticky Note4",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        1008,
        128
      ]
    },
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "triggerOn": "specificFolder",
        "folderToWatch": {
          "__rl": true,
          "value": "YOUR_FOLDER_ID",
          "mode": "list"
        },
        "event": "fileCreated",
        "options": {}
      },
      "id": "1f83f02b-23bd-4f2d-8dd8-6817255c395a",
      "name": "Google Drive Trigger",
      "type": "n8n-nodes-base.googleDriveTrigger",
      "typeVersion": 1,
      "position": [
        352,
        272
      ]
    },
    {
      "parameters": {
        "operation": "download",
        "fileId": {
          "__rl": true,
          "value": "={{ $json.id }}",
          "mode": "id"
        },
        "options": {}
      },
      "id": "0b6789e0-31fc-4866-aaeb-518ce728a603",
      "name": "Download file",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        528,
        272
      ]
    },
    {
      "parameters": {
        "operation": "extract",
        "inputType": "file",
        "prompt": "Extract receipt details as flat fields. storeName, storeAddress, receiptDate (YYYY-MM-DD), itemsList (all items as single string: name x qty @ price, semicolon-separated), subtotal (number), taxAmount (number), taxRate (number), total (number), paymentMethod, lastFourDigits, isTaxDeductible (true/false), deductionCategory (one of: Office Supplies, Business Meals, Travel, Equipment, Software, Professional Services, Marketing, Not Deductible).",
        "schema": "{\"type\": \"object\", \"properties\": {\"storeName\": {\"type\": \"string\"}, \"storeAddress\": {\"type\": \"string\"}, \"receiptDate\": {\"type\": \"string\"}, \"itemsList\": {\"type\": \"string\"}, \"subtotal\": {\"type\": \"number\"}, \"taxAmount\": {\"type\": \"number\"}, \"taxRate\": {\"type\": \"number\"}, \"total\": {\"type\": \"number\"}, \"paymentMethod\": {\"type\": \"string\"}, \"lastFourDigits\": {\"type\": \"string\"}, \"isTaxDeductible\": {\"type\": \"boolean\"}, \"deductionCategory\": {\"type\": \"string\"}}, \"additionalProperties\": false}"
      },
      "id": "906c71de-6e67-46e6-abb7-9525e4e06aa5",
      "name": "PDF Vector - Extract Receipt",
      "type": "n8n-nodes-pdfvector.pdfVector",
      "typeVersion": 2,
      "position": [
        704,
        272
      ],
      "credentials": {
        "pdfVectorApi": {
          "id": "SzTdgUBGHUbs4zxH",
          "name": "PDF Vector account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const receipt = ($input.first().json?.data || $input.first().json) || {};\n\nconst receiptId = `RCP-${Date.now().toString(36).toUpperCase()}`;\nconst receiptDate = new Date(receipt.receiptDate);\nconst taxYear = receiptDate.getFullYear() || new Date().getFullYear();\nconst quarter = Math.ceil((receiptDate.getMonth() + 1) / 3) || 1;\n\nreturn [{ json: {\n  receiptId,\n  storeName:         receipt.storeName         || 'Unknown',\n  storeAddress:      receipt.storeAddress      || 'N/A',\n  receiptDate:       receipt.receiptDate       || 'N/A',\n  itemsList:         receipt.itemsList         || 'Items not itemized',\n  subtotal:          parseFloat(receipt.subtotal) || 0,\n  taxAmount:         parseFloat(receipt.taxAmount) || 0,\n  total:             parseFloat(receipt.total) || 0,\n  paymentMethod:     receipt.paymentMethod     || 'N/A',\n  isTaxDeductible:   receipt.isTaxDeductible   || false,\n  deductionCategory: receipt.deductionCategory || 'Not Deductible',\n  taxYear,\n  quarter: `Q${quarter}`,\n  processedAt: new Date().toISOString()\n}}];"
      },
      "id": "71db1ce0-c485-42c6-acf3-2b51e11a84af",
      "name": "Process Receipt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        272
      ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "YOUR_SPREADSHEET_ID",
          "mode": "list"
        },
        "sheetName": {
          "__rl": true,
          "value": "Receipt Database",
          "mode": "list"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Receipt ID": "={{ $json.receiptId }}",
            "Date": "={{ $json.receiptDate }}",
            "Store": "={{ $json.storeName }}",
            "Items": "={{ $json.itemsList }}",
            "Subtotal": "={{ $json.subtotal || $json.total }}",
            "Tax": "={{ $json.taxAmount || 0 }}",
            "Total": "={{ $json.total }}",
            "Payment": "={{ $json.paymentMethod || 'N/A' }}",
            "Tax Deductible": "={{ $json.isTaxDeductible ? 'Yes' : 'No' }}",
            "Category": "={{ $json.deductionCategory || 'N/A' }}",
            "Tax Year": "={{ $json.taxYear }}",
            "Quarter": "={{ $json.quarter }}"
          }
        },
        "options": {}
      },
      "id": "5e12c08c-8ec3-4a89-85b6-ae1b455f8521",
      "name": "Log to Receipt Database",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        1072,
        272
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "deductible-check",
              "leftValue": "={{ $('Process Receipt').item.json.isTaxDeductible }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "03128c38-d6b3-4ec7-a1a9-ce7e827593f6",
      "name": "Tax Deductible?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1248,
        272
      ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "YOUR_SPREADSHEET_ID",
          "mode": "list"
        },
        "sheetName": {
          "__rl": true,
          "value": "Tax Deductions",
          "mode": "list"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Receipt ID": "={{ $('Process Receipt').item.json.receiptId }}",
            "Date": "={{ $('Process Receipt').item.json.receiptDate }}",
            "Vendor": "={{ $('Process Receipt').item.json.storeName }}",
            "Amount": "={{ $('Process Receipt').item.json.total }}",
            "Category": "={{ $('Process Receipt').item.json.deductionCategory }}",
            "Tax Year": "={{ $('Process Receipt').item.json.taxYear }}",
            "Quarter": "={{ $('Process Receipt').item.json.quarter }}"
          }
        },
        "options": {}
      },
      "id": "950da64e-6ae1-428e-aebe-42a2212105d1",
      "name": "Add to Tax Deductions",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        1440,
        160
      ]
    }
